// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

kairos_CODE_SIGN_STYLE = Automatic
kairos_DEVELOPMENT_TEAM = YOUR_TEAM_ID

kairos_APP_BUNDLE_ID = ai.kairos.client
kairos_SHARE_BUNDLE_ID = ai.kairos.client.share
kairos_ACTIVITY_WIDGET_BUNDLE_ID = ai.kairos.client.activitywidget
kairos_WATCH_APP_BUNDLE_ID = ai.kairos.client.watchkitapp
kairos_WATCH_EXTENSION_BUNDLE_ID = ai.kairos.client.watchkitapp.extension

// Leave empty with automatic signing.
kairos_APP_PROFILE =
kairos_SHARE_PROFILE =
kairos_WATCH_APP_PROFILE =
kairos_WATCH_EXTENSION_PROFILE =
