# kairos Podman environment
# Copy to kairos.podman.env.local and set kairos_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   kairos_PODMAN_ENV=/path/to/kairos.podman.env ./scripts/run-kairos-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-kairos-podman.sh which can generate it).
kairos_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# kairos_AI_SESSION_KEY=
# kairos_WEB_SESSION_KEY=
# kairos_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
kairos_PODMAN_GATEWAY_HOST_PORT=18789
kairos_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
kairos_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
