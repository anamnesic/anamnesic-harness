{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "DOM.Iterable", "ES2023", "ScriptHost"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noEmitOnError": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2023",
    "types": ["node"],
    "useDefineForClassFields": false,
    "paths": {
      "kairos/extension-api": ["./src/extensionAPI.ts"],
      "kairos/plugin-sdk": ["./src/plugin-sdk/index.ts"],
      "kairos/plugin-sdk/*": ["./src/plugin-sdk/*.ts"],
      "@kairos/sdk": ["./packages/sdk/src/index.ts"],
      "@kairos/plugin-sdk": ["./src/plugin-sdk/index.ts"],
      "@kairos/plugin-sdk/*": ["./src/plugin-sdk/*.ts"],
      "kairos/plugin-sdk/account-id": ["./src/plugin-sdk/account-id.ts"],
      "@kairos/*": ["./extensions/*"]
    }
  },
  "include": ["src/**/*", "ui/**/*", "extensions/**/*", "packages/**/*"],
  "exclude": ["node_modules", "dist", "**/dist/**"]
}
