{
  "name": "Kairos-vscode",
  "displayName": "Kairos",
  "description": "AI Context Management - maintain project context across all AI assistants",
  "version": "1.0.1",
  "publisher": "Kairos",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronokairo/Kairos.git"
  },
  "homepage": "https://github.com/chronokairo/Kairos",
  "bugs": {
    "url": "https://github.com/chronokairo/Kairos/issues"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "Kairos",
          "title": "Kairos",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "Kairos": [
        {
          "type": "webview",
          "id": "Kairos.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "Kairos.refreshProjects",
        "title": "Kairos: Refresh Projects"
      },
      {
        "command": "Kairos.createProject",
        "title": "Kairos: Create Project"
      },
      {
        "command": "Kairos.addContext",
        "title": "Kairos: Add Context Entry"
      },
      {
        "command": "Kairos.addFileAsContext",
        "title": "Kairos: Add File as Context"
      },
      {
        "command": "Kairos.addSelectionAsContext",
        "title": "Kairos: Add Selection as Context"
      },
      {
        "command": "Kairos.addStructureAsContext",
        "title": "Kairos: Add Workspace Structure as Context"
      },
      {
        "command": "Kairos.addDecision",
        "title": "Kairos: Record Decision"
      },
      {
        "command": "Kairos.syncContext",
        "title": "Kairos: Sync to AI Tools"
      },
      {
        "command": "Kairos.exportContext",
        "title": "Kairos: Export Context"
      },
      {
        "command": "Kairos.openContextFile",
        "title": "Kairos: Open Context File"
      },
      {
        "command": "Kairos.viewContext",
        "title": "Kairos: View Context Entry"
      },
      {
        "command": "Kairos.openChat",
        "title": "Kairos: Open AI Chat"
      },
      {
        "command": "Kairos.createPipeline",
        "title": "Kairos: Create Pipeline"
      },
      {
        "command": "Kairos.approvePhase",
        "title": "Kairos: Approve Phase"
      },
      {
        "command": "Kairos.rejectPhase",
        "title": "Kairos: Reject Phase"
      },
      {
        "command": "Kairos.viewTaskOutput",
        "title": "Kairos: View Task Output"
      },
      {
        "command": "Kairos.refreshPipeline",
        "title": "Kairos: Refresh Pipeline"
      },
      {
        "command": "Kairos.openOtherProject",
        "title": "Kairos: Open Other Project"
      },
      {
        "command": "Kairos.configureAgentModels",
        "title": "Kairos: Configure Agent Models"
      },
      {
        "command": "Kairos.runPhase",
        "title": "Kairos: Run Current Phase (Start Agents)"
      },
      {
        "command": "Kairos.stopAgents",
        "title": "Kairos: Stop All Agents"
      },
      {
        "command": "Kairos.invokeAgent",
        "title": "Kairos: Invoke Agent"
      },
      {
        "command": "Kairos.viewAgentModels",
        "title": "Kairos: View Agent Models"
      },
      {
        "command": "Kairos.showHistory",
        "title": "Kairos: Show Pipeline History",
        "icon": "$(history)"
      },
      {
        "command": "Kairos.backupHistory",
        "title": "Kairos: Backup Pipeline History"
      },
      {
        "command": "Kairos.restoreHistory",
        "title": "Kairos: Restore Pipeline History"
      },
      {
        "command": "Kairos.exportHistory",
        "title": "Kairos: Export Pipeline History"
      },
      {
        "command": "Kairos.toggleDryRun",
        "title": "Kairos: Toggle Dry-Run Mode",
        "icon": "$(beaker)"
      },
      {
        "command": "Kairos.openSafetyNet",
        "title": "Kairos: Open Safety Net Panel",
        "icon": "$(shield)"
      },
      {
        "command": "Kairos.rollback",
        "title": "Kairos: Rollback Phase",
        "icon": "$(discard)"
      },
      {
        "command": "Kairos.listSnapshots",
        "title": "Kairos: List Available Snapshots"
      },
      {
        "command": "Kairos.cleanupSnapshots",
        "title": "Kairos: Cleanup Old Snapshots"
      },
      {
        "command": "Kairos.history.refresh",
        "title": "Kairos: Refresh History",
        "icon": "$(refresh)"
      },
      {
        "command": "Kairos.advancedSoftware.generateCode",
        "title": "Kairos: Advanced Code Generation",
        "icon": "$(code)"
      },
      {
        "command": "Kairos.advancedSoftware.debugCode",
        "title": "Kairos: AI-Powered Code Debugging",
        "icon": "$(debug)"
      },
      {
        "command": "Kairos.advancedSoftware.refactorCode",
        "title": "Kairos: Intelligent Code Refactoring",
        "icon": "$(tools)"
      },
      {
        "command": "Kairos.advancedSecurity.scanVulnerabilities",
        "title": "Kairos: Comprehensive Security Scan",
        "icon": "$(shield-check)"
      },
      {
        "command": "Kairos.advancedSecurity.simulateAttack",
        "title": "Kairos: Attack Simulation (Controlled)",
        "icon": "$(warning)"
      },
      {
        "command": "Kairos.advancedSecurity.zeroDayDiscovery",
        "title": "Kairos: Zero-Day Vulnerability Discovery",
        "icon": "$(search)"
      },
      {
        "command": "Kairos.advancedMultimodal.analyzeImage",
        "title": "Kairos: AI Image Analysis",
        "icon": "$(file-media)"
      },
      {
        "command": "Kairos.advancedMultimodal.analyzeDiagram",
        "title": "Kairos: Diagram Interpretation",
        "icon": "$(graph)"
      },
      {
        "command": "Kairos.advancedMultimodal.synthesizeKnowledge",
        "title": "Kairos: Knowledge Synthesis",
        "icon": "$(book)"
      },
      {
        "command": "Kairos.reasoning.multiStepSolve",
        "title": "Kairos: Multi-Step Problem Solving",
        "icon": "$(lightbulb)"
      },
      {
        "command": "Kairos.reasoning.adaptiveThink",
        "title": "Kairos: Adaptive Deep Reasoning",
        "icon": "$(brain)"
      },
      {
        "command": "Kairos.workflow.createComplex",
        "title": "Kairos: Create Complex Workflow",
        "icon": "$(workflow)"
      },
      {
        "command": "Kairos.workflow.executeAutonomous",
        "title": "Kairos: Execute Autonomous Workflow",
        "icon": "$(play-circle)"
      },
      {
        "command": "Kairos.orchestrator.showRunStatus",
        "title": "Kairos: Orchestrator Run Status",
        "icon": "$(pulse)"
      },
      {
        "command": "Kairos.orchestrator.showCheckpoints",
        "title": "Kairos: Orchestrator Checkpoints",
        "icon": "$(list-unordered)"
      },
      {
        "command": "Kairos.orchestrator.pauseRun",
        "title": "Kairos: Pause Orchestrator Run",
        "icon": "$(debug-pause)"
      },
      {
        "command": "Kairos.orchestrator.resumeRun",
        "title": "Kairos: Resume Orchestrator Run",
        "icon": "$(debug-start)"
      },
      {
        "command": "Kairos.orchestrator.selectRun",
        "title": "Kairos: Select Orchestrator Run",
        "icon": "$(symbol-key)"
      },
      {
        "command": "Kairos.openAdvancedAgents",
        "title": "Kairos: Open Advanced AI Agents Panel",
        "icon": "$(robot)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "Kairos.addSelectionAsContext",
          "when": "editorHasSelection",
          "group": "Kairos"
        },
        {
          "command": "Kairos.addFileAsContext",
          "group": "Kairos"
        }
      ],
      "explorer/context": [
        {
          "command": "Kairos.addFileAsContext",
          "when": "!explorerResourceIsFolder",
          "group": "Kairos"
        }
      ],
      "view/title": [],
      "view/item/context": []
    },
    "configuration": {
      "title": "Kairos",
      "properties": {
        "Kairos.diffPreview": {
          "type": "string",
          "enum": [
            "always",
            "existing-only",
            "never"
          ],
          "default": "existing-only",
          "description": "When to show diff preview before write_file operations.",
          "enumDescriptions": [
            "Always show diff preview for all file writes",
            "Show diff preview only for existing files (default)",
            "Never show diff preview, write files directly"
          ]
        },
        "Kairos.commandConfirmation": {
          "type": "string",
          "enum": [
            "always",
            "destructive-only",
            "never"
          ],
          "default": "destructive-only",
          "description": "When to ask for confirmation before running shell commands.",
          "enumDescriptions": [
            "Always ask for confirmation before running any command",
            "Ask confirmation only for destructive commands (default)",
            "Never ask for confirmation, run commands directly"
          ]
        },
        "Kairos.safetynet.autoCleanup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically cleanup old snapshots on extension activation."
        },
        "Kairos.safetynet.retentionDays": {
          "type": "number",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Number of days to retain snapshots before automatic cleanup."
        },
        "Kairos.safetynet.maxSizeMB": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum total size in MB for snapshots per pipeline."
        },
        "Kairos.orchestrator.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for Kairos orchestrator API (example: http://localhost:3000)."
        },
        "Kairos.orchestrator.token": {
          "type": "string",
          "default": "",
          "description": "Bearer token for orchestrator API authentication."
        },
        "Kairos.orchestrator.workspaceId": {
          "type": "string",
          "default": "",
          "description": "Workspace ID used by remote orchestrator. If empty, derives from current folder name."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsc --watch",
    "package": "node esbuild.js && pnpm exec vsce package --no-dependencies",
    "publish:vsce": "pnpm exec vsce publish",
    "vscode:prepublish": "node esbuild.js"
  },
  "devDependencies": {
    "@Kairos/core": "workspace:*",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.6"
  }
}