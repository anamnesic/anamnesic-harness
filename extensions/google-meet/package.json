{
  "name": "@kairos/google-meet",
  "version": "2026.4.25",
  "description": "kairos Google Meet participant plugin",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.34"
  },
  "devDependencies": {
    "@kairos/plugin-sdk": "workspace:*",
    "kairos": "workspace:*"
  },
  "peerDependencies": {
    "kairos": ">=2026.4.25"
  },
  "peerDependenciesMeta": {
    "kairos": {
      "optional": true
    }
  },
  "kairos": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.4.25"
    },
    "build": {
      "kairosVersion": "2026.4.25"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
