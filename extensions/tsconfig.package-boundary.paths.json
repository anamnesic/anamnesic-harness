{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "kairos/extension-api": [
        "../src/extensionAPI.ts"
      ],
      "kairos/plugin-sdk": [
        "../dist/plugin-sdk/src/plugin-sdk/index.d.ts"
      ],
      "kairos/plugin-sdk/*": [
        "../dist/plugin-sdk/src/plugin-sdk/*.d.ts"
      ],
      "kairos/plugin-sdk/account-id": [
        "../dist/plugin-sdk/src/plugin-sdk/account-id.d.ts"
      ],
      "kairos/plugin-sdk/channel-entry-contract": [
        "../packages/plugin-sdk/dist/src/plugin-sdk/channel-entry-contract.d.ts"
      ],
      "kairos/plugin-sdk/browser-maintenance": [
        "../packages/plugin-sdk/dist/extensions/browser/browser-maintenance.d.ts"
      ],
      "kairos/plugin-sdk/channel-secret-basic-runtime": [
        "../packages/plugin-sdk/dist/src/plugin-sdk/channel-secret-basic-runtime.d.ts"
      ],
      "kairos/plugin-sdk/channel-secret-runtime": [
        "../dist/plugin-sdk/src/plugin-sdk/channel-secret-runtime.d.ts"
      ],
      "kairos/plugin-sdk/channel-secret-tts-runtime": [
        "../packages/plugin-sdk/dist/src/plugin-sdk/channel-secret-tts-runtime.d.ts"
      ],
      "kairos/plugin-sdk/channel-streaming": [
        "../dist/plugin-sdk/src/plugin-sdk/channel-streaming.d.ts"
      ],
      "kairos/plugin-sdk/error-runtime": [
        "../dist/plugin-sdk/src/plugin-sdk/error-runtime.d.ts"
      ],
      "kairos/plugin-sdk/provider-catalog-shared": [
        "../packages/plugin-sdk/dist/src/plugin-sdk/provider-catalog-shared.d.ts"
      ],
      "kairos/plugin-sdk/provider-entry": [
        "../packages/plugin-sdk/dist/src/plugin-sdk/provider-entry.d.ts"
      ],
      "kairos/plugin-sdk/secret-ref-runtime": [
        "../dist/plugin-sdk/src/plugin-sdk/secret-ref-runtime.d.ts"
      ],
      "kairos/plugin-sdk/ssrf-runtime": [
        "../dist/plugin-sdk/src/plugin-sdk/ssrf-runtime.d.ts"
      ],
      "@kairos/qa-channel/api.js": [
        "../dist/plugin-sdk/extensions/qa-channel/api.d.ts"
      ],
      "@kairos/*.js": [
        "../packages/plugin-sdk/dist/extensions/*.d.ts",
        "../extensions/*"
      ],
      "@kairos/*": [
        "../packages/plugin-sdk/dist/extensions/*",
        "../extensions/*"
      ],
      "@kairos/plugin-sdk/*": [
        "../dist/plugin-sdk/src/plugin-sdk/*.d.ts"
      ]
    }
  }
}
