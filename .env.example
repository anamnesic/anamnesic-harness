# ==============================================================================
# ThinkCoffee - Environment Variables (V4)
# ==============================================================================
# Copy this file to .env and customize:
#   cp .env.example .env
#
# Sections:
#   1. General
#   2. MCP Server
#   3. Data Paths
#   4. Safety Net (V3/V4)
#   5. Backup
#   6. Monitoring (optional)
#   7. Deploy (CI/CD)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. General
# ------------------------------------------------------------------------------
NODE_ENV=production
THINKCOFFEE_VERSION=latest
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# 2. MCP Server
# ------------------------------------------------------------------------------
MCP_PORT=3000

# Node.js memory limit (MB) -- adjust based on host capacity
NODE_OPTIONS=--max-old-space-size=256

# ------------------------------------------------------------------------------
# 3. Data Paths (inside container)
# ------------------------------------------------------------------------------
THINKCOFFEE_DATA_DIR=/data
THINKCOFFEE_DB_PATH=/data/data.sqlite
THINKCOFFEE_SNAPSHOT_DIR=/data/snapshots
THINKCOFFEE_LOG_DIR=/data/logs

# ------------------------------------------------------------------------------
# 4. Safety Net Configuration (V3/V4)
# ------------------------------------------------------------------------------

# Snapshot retention period (days). Snapshots older than this are auto-cleaned.
THINKCOFFEE_SNAPSHOT_RETENTION_DAYS=7

# Maximum size for snapshots per pipeline (MB).
THINKCOFFEE_SNAPSHOT_MAX_SIZE_MB=50

# Enable dry-run mode by default (prevents accidental writes).
# Values: true | false
THINKCOFFEE_DRY_RUN_DEFAULT=false

# Diff preview mode for write_file operations.
# Values: always | existing-only | never
THINKCOFFEE_DIFF_PREVIEW_MODE=existing-only

# Command confirmation popup behavior.
# Values: always | destructive-only | never
THINKCOFFEE_COMMAND_CONFIRMATION=destructive-only

# ------------------------------------------------------------------------------
# 5. Backup Configuration
# ------------------------------------------------------------------------------

# How many days to keep backups
BACKUP_RETENTION_DAYS=30

# Maximum number of backups to keep
MAX_BACKUP_COUNT=10

# ------------------------------------------------------------------------------
# 6. Monitoring (optional -- used by docker-compose.monitoring.yml)
# ------------------------------------------------------------------------------
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=thinkcoffee
# ALERTMANAGER_PORT=9093

# ------------------------------------------------------------------------------
# 7. Deploy (CI/CD -- configure as GitHub Secrets, NOT here)
# ------------------------------------------------------------------------------
# DEPLOY_HOST=your-server.example.com
# DEPLOY_USER=deploy
# DEPLOY_SSH_KEY=<private key content>
# DEPLOY_URL=https://your-server.example.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# NPM_TOKEN=npm_...
# VSCE_PAT=...
# CODECOV_TOKEN=...
