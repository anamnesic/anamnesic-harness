# ThinkCoffee Config (V3 - Agent Safety Net)
# Copie para .env e adapte conforme necessario

# =================
# Core Configuration
# =================
NODE_ENV=production
LOG_LEVEL=info # debug | info | warn | error

# =================
# Storage & Paths
# =================
# Diretorio base montado no container
THINKCOFFEE_DATA_DIR=/data

# Base de Dados (SQLite)
THINKCOFFEE_DB_PATH=/data/data.sqlite

# Agent Safety Net (V3) Storage
THINKCOFFEE_SNAPSHOT_DIR=/data/snapshots
THINKCOFFEE_LOG_DIR=/data/logs

# =================
# V3 Agent Safety Net Policy
# =================

# Dry-Run Mode default: false
# Se true, simula as acoes sem alterar o SO (exceto tools seguras como read_file)
THINKCOFFEE_DRY_RUN_DEFAULT=false

# Visualizacao de Diffs antes da aprovacao
# none | existing-only | all
THINKCOFFEE_DIFF_PREVIEW_MODE=existing-only

# Regra de Confirmacao de Comandos
# always | destructive-only | never
THINKCOFFEE_COMMAND_CONFIRMATION=destructive-only

# Garbage Collection (Snapshots)
THINKCOFFEE_SNAPSHOT_RETENTION_DAYS=7       # Retencao em dias
THINKCOFFEE_SNAPSHOT_MAX_SIZE_MB=100        # Limite global (MB)

# =================
# MCP Server Networking
# =================
MCP_PORT=3000
MCP_HOST=0.0.0.0
