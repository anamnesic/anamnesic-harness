# ==============================================================================
# ThinkCoffee - Environment Variables
# ==============================================================================
# Copie este arquivo para .env e preencha os valores
#   cp .env.example .env
#
# NUNCA commite o arquivo .env com valores reais.
# ==============================================================================

# ------------------------------------------------------------------------------
# RUNTIME
# ------------------------------------------------------------------------------
NODE_ENV=development
# Valores: development | test | production

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# Caminho absoluto para o arquivo SQLite.
# Em container: mantido via volume em /data/data.sqlite
# Localmente: ~/.thinkcoffee/data.sqlite (default se nao definido)
THINKCOFFEE_DB_PATH=/data/data.sqlite
THINKCOFFEE_DATA_DIR=/data

# ------------------------------------------------------------------------------
# MCP SERVER
# ------------------------------------------------------------------------------
# Porta exposta pelo servidor MCP (HTTP transport)
MCP_PORT=3000

# Caminho absoluto do workspace do projeto analisado pelo MCP
THINKCOFFEE_WORKSPACE=

# ------------------------------------------------------------------------------
# AUTO-EXPORT / SYNC (Feature #5)
# ------------------------------------------------------------------------------
# Habilita sincronizacao automatica
THINKCOFFEE_AUTO_SYNC_ENABLED=false

# Intervalo de sync em segundos (default: 300 = 5 minutos)
THINKCOFFEE_AUTO_SYNC_INTERVAL=300

# Arquivo destino do sync
THINKCOFFEE_SYNC_TARGET=.github/copilot-instructions.md

# Formatos de export: copilot | cursor | windsurf | all
THINKCOFFEE_SYNC_FORMATS=copilot

# Habilita watch de arquivos para sync reativo
THINKCOFFEE_SYNC_WATCH=false

# ------------------------------------------------------------------------------
# AI OPTIMIZATION (Feature #4)
# ------------------------------------------------------------------------------
# Provider: openai | anthropic | disabled
THINKCOFFEE_AI_PROVIDER=disabled

# API Key do provider (obrigatorio se provider != disabled)
THINKCOFFEE_AI_API_KEY=

# Modelo a ser usado
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
THINKCOFFEE_AI_MODEL=gpt-4o-mini

# Threshold de similaridade para deteccao de duplicatas (0.0 - 1.0)
THINKCOFFEE_AI_SIMILARITY_THRESHOLD=0.85

# Max tokens por requisicao
THINKCOFFEE_AI_MAX_TOKENS=4096

# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------
# Nivel de log: error | warn | info | debug
LOG_LEVEL=info

# Habilita logging de queries SQL (apenas dev/debug)
THINKCOFFEE_DB_LOGGING=false

# ------------------------------------------------------------------------------
# DEPLOY / CI
# ------------------------------------------------------------------------------
# Registry para push de imagens Docker
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=thinkcoffee/mcp-server

# ------------------------------------------------------------------------------
# SECRETS (definir via GitHub Actions Secrets ou .env local)
# NUNCA versionar valores reais destes secrets
# ------------------------------------------------------------------------------
# NPM_TOKEN=npm_xxxxx
# DOCKER_USERNAME=
# DOCKER_PASSWORD=
# OPENAI_API_KEY=sk-xxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxx
