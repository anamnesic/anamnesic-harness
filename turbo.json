{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": [
    "CI",
    "kairos_DISABLE_SHARE"
  ],
  "globalPassThroughEnv": [
    "CI",
    "kairos_DISABLE_SHARE"
  ],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": [
        "dist/**"
      ]
    },
    "kairos#test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "passThroughEnv": [
        "*"
      ]
    },
    "kairos#test:ci": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".artifacts/unit/junit.xml"
      ],
      "passThroughEnv": [
        "*"
      ]
    }
  }
}
