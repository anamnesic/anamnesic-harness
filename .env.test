# ==============================================================================
# ThinkCoffee - Test Environment Variables
# ==============================================================================
NODE_ENV=test
LOG_LEVEL=error
THINKCOFFEE_DB_PATH=:memory:
THINKCOFFEE_DATA_DIR=/tmp/thinkcoffee-test
THINKCOFFEE_SNAPSHOT_DIR=/tmp/thinkcoffee-test/snapshots
THINKCOFFEE_LOG_DIR=/tmp/thinkcoffee-test/logs
THINKCOFFEE_SNAPSHOT_RETENTION_DAYS=1
THINKCOFFEE_SNAPSHOT_MAX_SIZE_MB=10
THINKCOFFEE_DRY_RUN_DEFAULT=true
THINKCOFFEE_DIFF_PREVIEW_MODE=never
THINKCOFFEE_COMMAND_CONFIRMATION=never
THINKCOFFEE_AUTO_EXPORT_ENABLED=false
THINKCOFFEE_AUTO_EXPORT_INTERVAL_MS=1000
THINKCOFFEE_AUTO_EXPORT_TARGETS=.github/copilot-instructions.md,.cursorrules
