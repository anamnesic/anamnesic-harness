# ==============================================================================
# Kairos - Test Environment Variables
# ==============================================================================
NODE_ENV=test
LOG_LEVEL=error
Kairos_DB_PATH=:memory:
Kairos_DATA_DIR=/tmp/Kairos-test
Kairos_SNAPSHOT_DIR=/tmp/Kairos-test/snapshots
Kairos_LOG_DIR=/tmp/Kairos-test/logs
Kairos_SNAPSHOT_RETENTION_DAYS=1
Kairos_SNAPSHOT_MAX_SIZE_MB=10
Kairos_DRY_RUN_DEFAULT=true
Kairos_DIFF_PREVIEW_MODE=never
Kairos_COMMAND_CONFIRMATION=never
Kairos_AUTO_EXPORT_ENABLED=false
Kairos_AUTO_EXPORT_INTERVAL_MS=1000
Kairos_AUTO_EXPORT_TARGETS=.github/copilot-instructions.md,.cursorrules
