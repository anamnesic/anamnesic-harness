{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "jsx": "react-jsx",
        "lib": [
            "ES2020"
        ],
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "rootDir": "./packages/core/src/agent"
    },
    "include": [
        "packages/core/src/agent"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "data",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}