{
  "name": "kairos",
  "displayName": "Kairos",
  "version": "1.0.0",
  "private": true,
  "description": "Persistent, proactive AI agent with continuous memory, observation, and autonomous action.",
  "main": "./dist/interfaces/dashboard/extension.js",
  "publisher": "Kairos",
  "repository": {
    "type": "git",
    "url": "https://github.com/chronokairo/Kairos.git"
  },
  "homepage": "https://github.com/chronokairo/Kairos",
  "bugs": {
    "url": "https://github.com/chronokairo/Kairos/issues"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kairos-sidebar",
          "title": "Kairos",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "kairos-sidebar": [
        {
          "id": "Kairos.conversations",
          "name": "Conversations",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "kairos.llmServer.start",
        "title": "Kairos LLM Server: Start"
      },
      {
        "command": "kairos.llmServer.stop",
        "title": "Kairos LLM Server: Stop"
      },
      {
        "command": "kairos.llmServer.status",
        "title": "Kairos LLM Server: Show Status"
      },
      {
        "command": "kairos.llmServer.listModels",
        "title": "Kairos LLM Server: List Available Models"
      },
      {
        "command": "Kairos.openSettings",
        "title": "Kairos: Open Settings"
      },
      {
        "command": "Kairos.openMcpSettings",
        "title": "Kairos: Open MCP Settings"
      },
      {
        "command": "Kairos.openSkills",
        "title": "Kairos: Open Skills"
      }
    ],
    "configuration": {
      "title": "Kairos LLM Server",
      "properties": {
        "kairos.llmServer.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host address to bind the LLM server to. Use '0.0.0.0' to listen on all interfaces (not recommended)."
        },
        "kairos.llmServer.port": {
          "type": "number",
          "default": 11434,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port number for the Ollama-compatible LLM API server."
        },
        "kairos.llmServer.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the LLM server when VS Code opens."
        }
      }
    }
  },
  "bin": {
    "kairos-mcp": "dist/interfaces/api/index.js",
    "kairos-api": "dist/interfaces/api/start-api.js",
    "think": "dist/interfaces/cli/index.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build && next export",
    "tauri:build": "pnpm run export && pnpm tauri build",
    "start": "next start",
    "postinstall": "pnpm rebuild node-pty",
    "build:backend": "tsc --project tsconfig.build.json",
    "build:vscode": "node esbuild.vscode.js",
    "start:api": "node dist/interfaces/api/start-api.js",
    "start:cli": "node dist/interfaces/cli/index.js",
    "start:swe-agent": "node dist/interfaces/cli/index.js swe-agent run",
    "test": "node scripts/test-integration.js",
    "test:readme": "vitest run src/__tests__/readme-concepts.test.ts",
    "test:concepts": "pnpm run test:readme",
    "test:swe-agent": "vitest run src/core/agents/__tests__/mini-swe-agent.test.ts",
    "test:swe-agent:integration": "tsx scripts/test-swe-agent-integration.ts",
    "test:unit": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "ci:install": "pnpm install --frozen-lockfile",
    "docker:build": "docker build -f Dockerfile -t kairos:local .",
    "docker:build:cli": "docker build -f Dockerfile.cli -t kairos-cli:local .",
    "package:vscode": "node esbuild.vscode.js && pnpm exec vsce package --no-dependencies"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.15.2",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "hono": "^4.12.15",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "pdf-parse": "^1.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.1.13",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "typeorm": "^0.3.28",
    "uuid": "^14.0.0",
    "xterm": "^5.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/adm-zip": "^0.5.8",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.1.6",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "onlyBuiltDependencies": [
    "sqlite3"
  ],
  "keywords": [
    "ai",
    "agent",
    "memory",
    "mcp",
    "model-context-protocol",
    "cli",
    "developer-tools"
  ],
  "author": "Kairos Team",
  "license": "MIT"
}