    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/openai-compatible": "^0.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  }
}
